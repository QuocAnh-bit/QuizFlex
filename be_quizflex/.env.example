APP_NAME=QuizFlex
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quizflex
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=quizflex-app
REVERB_APP_KEY=quizflex-key
REVERB_APP_SECRET=quizflex-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URI=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
DEEPSEEK_BASE_URI=
DEEPSEEK_MODEL=
DEEPSEEK_TIMEOUT=120
DEEPSEEK_CONNECT_TIMEOUT=30
DEEPSEEK_SSL_VERIFY=true
DEEPSEEK_CA_BUNDLE=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

TESSERACT_PATH=G:/QuizFlex/tesseract.exe
TESSERACT_LANG=eng
