APP_NAME=QuizFlex
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quizflex
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync


SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

TESSERACT_PATH=G:/QuizFlex/tesseract.exe
TESSERACT_LANG=eng

# AI provider configuration
# Use DeepSeek directly by default. Put your real DeepSeek Platform key here.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URI=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Leave OPENROUTER_API_KEY empty unless you are using an OpenRouter key that starts with sk-or-v1-.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URI=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
